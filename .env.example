# Porta do servidor Bun
PORT=3000

# Token de verificação do webhook (você define livremente, deve ser o mesmo no painel da Meta)
META_VERIFY_TOKEN=

# App Secret (Meta Developers → Seu App → Configurações → Básico → Chave Secreta do Aplicativo)
META_APP_SECRET=

# Chave de acesso à API de gerenciamento do Gateway (rotas /api/*)
# Gere uma chave forte: openssl rand -hex 32
GATEWAY_API_KEY=

# [LEGADO] URL de produção do webhook n8n — usado como fallback quando phone_number_id não está no banco
# Será removido quando todos os clientes estiverem cadastrados via API
WEBHOOK_URL_N8N=

# ─── GHL (GoHighLevel) Marketplace ──────────────────────────────

# Client ID e Secret do app no GHL Marketplace
# (GHL Marketplace → Meu App → Settings → Client ID / Client Secret)
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=

# Conversation Provider ID — criado ao registrar seu app como provedor de conversas
# (GHL Marketplace → Meu App → Conversation Provider → Provider ID)
GHL_CONVERSATION_PROVIDER_ID=

# Escopos OAuth necessários (separados por espaço)
GHL_SCOPES=conversations/message.readonly conversations/message.write contacts.readonly contacts.write

# URL pública do gateway (usada como redirect_uri no OAuth e base para webhooks)
GATEWAY_PUBLIC_URL=https://gateway.harucode.com.br

# Admin Dashboard
# Defina uma senha forte para acessar /admin
ADMIN_PASSWORD=
